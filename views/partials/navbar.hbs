<style>
    .header__btns {
        display: flex;
        align-items: center;
    }

    .header__btns .logout {
        padding: 8px 20px;
        background-color: #FFD700;
        color: #000;
        font-weight: bold;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: all 0.3s ease;
    }


    .header__btns .logout:hover {
        background-color: #FFC000;
        color: #fff;
        transform: scale(1.05);
    }
</style>
<header class="header">
    <div class="container">
        <div class="header__box">

            <div class="logo">
                <h2>QARZ SYSTEM</h2>
            </div>

            {{#if user}}
            <nav class="nav">
                <a href="/debt">Asosiy</a>
                <a href="/debt/add">Qarz qo'shish</a>
                <a href="/debt/blacklist">Black list</a>
            </nav>

            <div class="header__btns">
                <a href="/auth/logout">
                    <button class="logout">Logout</button>
                </a>
            </div>
            {{else}}
            <div class="header__btns">
                <a href="/auth/login">
                    <button class="login">Login</button>
                </a>
                <a href="/auth/register">
                    <button class="register">Register</button>
                </a>
            </div>
            {{/if}}

        </div>
    </div>
</header>