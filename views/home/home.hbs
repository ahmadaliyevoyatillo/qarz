<style>
    body {
        font-family: 'Arial', sans-serif;
        background: #fff8e7;
        margin: 0;
        padding: 0;
    }

    .container {
        width: 1100px;
        margin: auto;
    }

    .header {
        background: linear-gradient(90deg, #ffc107, #ffb300);
        color: black;
        padding: 25px;
        margin-top: 20px;
        border-radius: 10px;
        font-size: 24px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        text-align: center;
    }

    .table-box {
        background: #fff3cd;
        margin-top: 20px;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #ffc107;
        color: black;
        padding: 15px;
        text-align: left;
        border-radius: 6px;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #ffe08a;
    }

    tr:hover {
        background: #fff9e6;
    }

    .paid {
        background: #16a34a;
        color: white;
        padding: 5px 10px;
        border-radius: 6px;
        font-weight: bold;
    }

    .unpaid {
        background: #dc2626;
        color: white;
        padding: 5px 10px;
        border-radius: 6px;
        font-weight: bold;
        text-decoration: none;
    }

    .status-btn {
        background: #f59e0b;
        color: white;
        padding: 8px 15px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

    .status-btn:hover {
        background: #d97706;
    }

    .paid-row {
        background: #e6f4ea;
    }

    .unpaid-row {
        background: #fff2e6;
    }

    .delete {
        background: red;
        color: white;
        padding: 6px 12px;
        border-radius: 5px;
        text-decoration: none
    }

    .box {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .blacklist-btn {
        background: black;
        color: white;
        padding: 8px 15px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        transition: .3s;
    }

    .blacklist-btn:hover {
        background: #262626;
    }

    .box {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: stretch;
        width: 140px;
    }

    .status-btn,
    .blacklist-btn,
    .delete {

        display: block;
        text-align: center;
        width: 100%;
        padding: 8px 0;
        border-radius: 7px;
        font-weight: bold;
        text-decoration: none;

    }

    .box {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
        width: 150px;
    }


    .box {
        display: flex;
        flex-direction: column;
        gap: 10px;
        width: 150px;
    }

    .status-btn {
        background: #f59e0b;
        color: white;
        padding: 8px;
        border-radius: 6px;
        text-align: center;
        text-decoration: none;
    }

    .blacklist-btn {
        background: black;
        color: white;
        padding: 8px;
        border-radius: 6px;
    }

    .delete {
        background: red;
        color: white;
        padding: 8px;
        border-radius: 6px;
        text-align: center;
    }

    /* =======================
   RESPONSIVE DESIGN
======================= */

    /* Planshet */
    @media (max-width: 992px) {

        .container {
            width: 100%;
            padding: 0 15px;
        }

        .header__box {
            flex-direction: column;
            gap: 15px;
        }

        .nav {
            gap: 20px;
        }

        table {
            font-size: 14px;
        }

    }

    /* Telefon */
    @media (max-width:768px) {

        .logo h2 {
            font-size: 22px;
        }

        .nav {
            flex-direction: column;
            width: 100%;
            gap: 10px;
        }

        .nav a {
            display: block;
            width: 100%;
            background: #fff3cd;
            padding: 8px;
            border-radius: 6px;
        }

        .header__btns {
            width: 100%;
            flex-direction: column;
        }

        .login,
        .register,
        .logout {
            width: 100%;
        }

        .lend-form {
            width: 95%;
            margin: 20px auto;
        }

        form {
            width: 95%;
        }

        .container {
            width: 100%;
        }

        table {
            min-width: 500px;
        }

    }

    /* Kichik telefon */
    @media (max-width:480px) {

        .logo h2 {
            font-size: 20px;
        }

        .header {
            padding: 15px 0;
        }

        .lend-form {
            padding: 15px;
        }

        th,
        td {
            padding: 8px;
            font-size: 13px;
        }

        button {
            font-size: 14px;
        }

    }
</style>

<div class="container">

    <div class="header">
        <h1>Qarzdorlar ro'yhati</h1>
    </div>

    <input type="text" id="searchInput" placeholder="Ism bo'yicha qidirish..." style="
width:300px;
padding:10px;
margin:15px 0;
border:2px solid #ffc107;
border-radius:6px;
font-size:16px;
">

    <div class="table-box">

        <table>
            <thead>
                <tr>
                    <th>Ism</th>
                    <th>Summa</th>
                    <th>Berilgan kun</th>
                    <th>Olinadigan kun</th>
                    <th>Holati</th>
                    <th>Holat ishi</th>
                </tr>
            </thead>
            <tbody>
                {{#each lends}}
                <tr>

                    <td>{{full_name}}</td>

                    <td>{{summa}} so'm</td>

                    <td>{{give_day}}</td>

                    <td>{{take_day}}</td>

                    <td class="status-cell">
                        <span class="unpaid">
                            To'lanmagan
                        </span>
                    </td>

                    <td>
                        <div class="box">
                            <button class="status-btn toggle-paid-btn" data-id="{{id}}">
                                To'landi
                            </button>

                            <button class="blacklist-btn" data-id="{{id}}">
                                Qora ro'yxat
                            </button>

                            <a href="/debt/delete/{{id}}" class="delete">
                                O'chirish
                            </a>

                            <a href="/debt/edit/{{id}}" class="status-btn">
                                Yangilash
                            </a>
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>

    </div>

</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {

        const buttons = document.querySelectorAll('.toggle-paid-btn');

        buttons.forEach(btn => {
            const row = btn.closest('tr');
            const id = btn.dataset.id;
            const statusCell = row.querySelector('.status-cell span');

            // Boshlang'ich statusni localStorage dan o'qib olamiz
            let paid = localStorage.getItem("paid_" + id);
            if (paid === null) {
                // Agar localStorage bo'sh bo'lsa, default = false (To'lanmagan)
                paid = false;
            } else {
                paid = paid === "true";
            }

            // Tugma va statusni boshlang'ich holatga qo'yish
            const setStatus = () => {
                if (paid) {
                    statusCell.textContent = "To'landi";
                    statusCell.classList.remove('unpaid');
                    statusCell.classList.add('paid');
                    btn.textContent = "To'lanmadi";
                } else {
                    statusCell.textContent = "To'lanmagan";
                    statusCell.classList.remove('paid');
                    statusCell.classList.add('unpaid');
                    btn.textContent = "To'landi";
                }
            };

            setStatus();

            btn.addEventListener('click', () => {
                paid = !paid;      // Toggle holat
                btn.addEventListener('click', async () => {

                    await fetch("/debt/toggle/" + id, {
                        method: "POST"
                    })

                    location.reload()

                });
                setStatus();       // Status va tugmani yangilash
            });
        });

        // BLACKLIST tugmalari
        const blackButtons = document.querySelectorAll('.blacklist-btn');

        blackButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const row = e.target.closest('tr');
                const id = btn.dataset.id;
                const data = {
                    id: id,
                    name: row.children[0].textContent,
                    summa: row.children[1].textContent,
                    give: row.children[2].textContent,
                    take: row.children[3].textContent
                };

                let blacklist = JSON.parse(localStorage.getItem("blacklist")) || [];
                if (!blacklist.find(item => item.id == id)) {
                    blacklist.push(data);
                }

                localStorage.setItem("blacklist", JSON.stringify(blacklist));
                window.location.href = "debt/blacklist";
            });
        });

    });


    const searchInput = document.getElementById("searchInput")

    searchInput.addEventListener("keyup", function () {

        let filter = searchInput.value.toLowerCase()

        let rows = document.querySelectorAll("tbody tr")

        rows.forEach(row => {

            let name = row.children[0].textContent.toLowerCase()

            if (name.includes(filter)) {
                row.style.display = ""
            } else {
                row.style.display = "none"
            }

        })

    })
</script>