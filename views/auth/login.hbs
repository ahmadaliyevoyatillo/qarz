<style>
    form {
        max-width: 400px;
        margin: 50px auto;
        padding: 20px;
        background-color: #fff8e7;
        /* engil sariq fon */
        border: 2px solid #FFD700;
        /* sariq chekka */
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        gap: 15px;
        font-family: Arial, sans-serif;
    }

    .bode {
        position: relative;
        top: 100px;
    }

    input {
        padding: 10px;
        border: 1px solid #FFD700;
        border-radius: 5px;
        font-size: 16px;
    }

    button {
        padding: 10px;
        background-color: #FFD700;
        /* sariq tugma */
        border: none;
        border-radius: 5px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.3s;
    }

    button:hover {
        background-color: #FFC000;
        /* hover effekti */
    }

    a {
        text-align: center;
        color: #FFA500;
        text-decoration: none;
        font-weight: bold;
    }

    a:hover {
        text-decoration: underline;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
    }


    .container {
        width: 1200px;
        margin: auto;
    }

    /* HEADER */

    .header {
        background: linear-gradient(90deg, #FFD700, #FFC000, #FFB300);
        padding: 20px 0;
        box-shadow: 0 5px 25px rgba(255, 200, 0, 0.4);
    }

    .header__box {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /* LOGO */

    .logo h2 {
        color: black;
        font-size: 28px;
        font-weight: 800;
    }

    /* NAV */

    .nav {
        display: flex;
        gap: 40px;
    }

    .nav a {
        text-decoration: none;
        color: black;
        font-size: 18px;
        font-weight: 600;
        transition: .3s;
    }

    .nav a:hover {
        color: white;
        transform: scale(1.1);
    }

    /* BUTTONS */

    .header__btns {
        display: flex;
        gap: 15px;
    }

    .login {
        padding: 10px 25px;
        border: none;
        background: black;
        color: gold;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: .3s;
    }

    .login:hover {
        background: white;
        color: black;
    }

    .credit {
        padding: 10px 25px;
        border: none;
        background: white;
        color: black;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        transition: .3s;
    }

    .credit:hover {
        background: black;
        color: gold;
    }






    .lend-form {
        display: flex;
        flex-direction: column;
        gap: 15px;
        width: 300px;
    }

    .lend-form input {
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
    }

    .lend-form button {
        padding: 12px;
        background: #3498db;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

    /* RESPONSIVE */

    @media (max-width: 1200px) {
        .container {
            width: 95%;
        }
    }

    @media (max-width: 768px) {

        form,
        .form-register {
            max-width: 90%;
            margin: 30px auto;
            padding: 15px;
        }

        input {
            font-size: 14px;
            padding: 8px;
        }

        button {
            font-size: 14px;
            padding: 8px;
        }

        .header__box {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

        .nav {
            flex-direction: column;
            gap: 15px;
        }

        .header__btns {
            flex-direction: column;
            width: 100%;
        }

        .login,
        .credit {
            width: 100%;
        }

    }

    @media (max-width: 480px) {

        form,
        .form-register {
            max-width: 95%;
            padding: 12px;
        }

        .logo h2 {
            font-size: 22px;
        }

        .nav a {
            font-size: 16px;
        }

        input {
            font-size: 13px;
        }

        button {
            font-size: 13px;
        }

    }

    .loginTitle {
        font-family: sans-serif;
        font-weight: 600;
        font-size: 30px;
        color: #FFC000;
        text-align: center;
    }
</style> 


<div class="bode">
    <form action="/auth/login" method="POST">
        <h2 class="loginTitle">Kirish</h2>

        <input name="email" type="email" placeholder="Email">
        <input name="password" type="password" placeholder="Parol">
        <button type="submit">Kirish</button>
        <a href="/auth/register">Akkaunt Yaratish</a>
    </form>
</div>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const params = new URLSearchParams(window.location.search)

    if (params.get("error") === "email") {
        alert("Email topilmadi")
    }

    if (params.get("error") === "password") {
        alert("Password noto'g'ri")
    }

    if (params.get("error") === "server") {
        alert("Server xatosi")
    }

    if (params.get("success") === "register") {
        alert("Register muvaffaqiyatli")
    }

    if (params.get("success") === "logout") {
        alert("Chiqdingiz")
    }

    if (params.get("error") === "code") {
        alert("Email kodi noto'g'ri")
    }
    if (params.get("error") === "passwordshort") {
        alert("Password kamida 8 belgidan iborat bo'lishi kerak")
    }
</script>