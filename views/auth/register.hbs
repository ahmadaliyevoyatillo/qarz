<form action="/auth/register" method="POST" class="form-register">
    <h2>Akkunt Yaratish</h2>
    <input name="user_name" type="name" placeholder="To'liq ismingiz" required>
    <input name="born_day" type="date" placeholder="Tug'ilgan sana" required>
    <input name="email" type="email" placeholder="Email" pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
        title="To'g'ri email kiriting (example@gmail.com)" required>
    <input name="password" type="password" placeholder="Parol" required>
    <input name="telegram_id" placeholder="Telegram ID" required>
    <button type="submit">Akkaunt Yaratish</button>
    <p>Akkuntiz bormi <a href="/auth/login">Kirish</a></p>
</form>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const params = new URLSearchParams(window.location.search)

    if (params.get("error") === "email") {
        alert("Email topilmadi")
    }

    if (params.get("error") === "password") {
        alert("Password noto'g'ri")
    }

    if (params.get("error") === "server") {
        alert("Server xatosi")
    }

    if (params.get("success") === "register") {
        alert("Register muvaffaqiyatli")
    }

    if (params.get("success") === "logout") {
        alert("Chiqdingiz")
    }
    if (params.get("error") === "emailformat") {
        alert("To'g'ri email kiriting (example@gmail.com)")
    }
    if (params.get("error") === "code") {
        alert("Email kodi noto'g'ri")
    }
    if (params.get("error") === "passwordshort") {
        alert("Password kamida 8 belgidan iborat bo'lishi kerak")
    }
</script>